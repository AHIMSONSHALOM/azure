@model ProductHub_MVC.Models.SystemStatusDto
@{
    ViewData["Title"] = "System Health Dashboard";
}

<div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight" style="font-family: 'Poppins', sans-serif;">System Status Console</h1>
            <p class="text-gray-500 mt-1">Real-time health pings, network metrics, and background service registry</p>
        </div>
        <div>
            <a asp-action="Index" asp-controller="Product" class="inline-flex items-center px-4 py-2 bg-indigo-50 text-indigo-700 font-bold rounded-lg hover:bg-indigo-100 transition text-decoration-none">
                <i class="fa-solid fa-house mr-2"></i> Catalog Feed
            </a>
        </div>
    </div>

    <!-- Health Widgets Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        
        <!-- 1. Database Status Card -->
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-between h-56 relative overflow-hidden group">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 text-xl">
                        <i class="fa-solid fa-database"></i>
                    </div>
                    <span class="badge @(Model.DbStatus.IsOnline ? "bg-success" : "bg-danger") px-3 py-1.5 rounded-full text-xs font-bold uppercase">
                        @(Model.DbStatus.IsOnline ? "Online" : "Offline")
                    </span>
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-1" style="font-family: 'Poppins', sans-serif;">Local SQL Database</h3>
                <p class="text-xs text-gray-400 font-mono truncate">@Model.DbStatus.ConnectionString</p>
            </div>
            
            <div class="border-t border-gray-100 pt-4 flex justify-between items-center mt-auto">
                <span class="text-xs text-gray-400 font-medium">Ping Response:</span>
                <span class="font-mono font-bold @(Model.DbStatus.LatencyMs > 100 ? "text-amber-600" : "text-green-600")">
                    @(Model.DbStatus.LatencyMs >= 0 ? $"{Model.DbStatus.LatencyMs} ms" : "Timeout")
                </span>
            </div>
        </div>

        <!-- 2. FastAPI AI Service Card -->
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-between h-56 relative overflow-hidden group">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-2xl bg-teal-50 flex items-center justify-center text-teal-600 text-xl">
                        <i class="fa-solid fa-server"></i>
                    </div>
                    <span class="badge @(Model.ApiStatus.IsOnline ? "bg-success" : "bg-danger") px-3 py-1.5 rounded-full text-xs font-bold uppercase">
                        @(Model.ApiStatus.IsOnline ? "Online" : "Offline")
                    </span>
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-1" style="font-family: 'Poppins', sans-serif;">FastAPI AI Service</h3>
                <p class="text-xs text-gray-400 font-mono">@Model.ApiStatus.Url</p>
            </div>
            
            <div class="border-t border-gray-100 pt-4 flex justify-between items-center mt-auto">
                <span class="text-xs text-gray-400 font-medium">Ping Response:</span>
                <span class="font-mono font-bold @(Model.ApiStatus.LatencyMs > 200 ? "text-amber-600" : "text-green-600")">
                    @(Model.ApiStatus.LatencyMs >= 0 ? $"{Model.ApiStatus.LatencyMs} ms" : "Timeout")
                </span>
            </div>
        </div>

        <!-- 3. Ollama Inference Engine Card -->
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col justify-between h-56 relative overflow-hidden group">
            <div>
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-2xl bg-purple-50 flex items-center justify-center text-purple-600 text-xl">
                        <i class="fa-solid fa-microchip"></i>
                    </div>
                    <span class="badge @(Model.OllamaStatus.IsOnline ? "bg-success" : "bg-danger") px-3 py-1.5 rounded-full text-xs font-bold uppercase">
                        @(Model.OllamaStatus.IsOnline ? "Online" : "Offline")
                    </span>
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-1" style="font-family: 'Poppins', sans-serif;">Ollama LLM Engine</h3>
                <p class="text-xs text-gray-400 font-mono">@Model.OllamaStatus.Url</p>
            </div>
            
            <div class="border-t border-gray-100 pt-4 flex justify-between items-center mt-auto">
                <span class="text-xs text-gray-400 font-medium">Ping Response:</span>
                <span class="font-mono font-bold @(Model.OllamaStatus.LatencyMs > 1000 ? "text-amber-600" : "text-green-600")">
                    @(Model.OllamaStatus.LatencyMs >= 0 ? $"{Model.OllamaStatus.LatencyMs} ms" : "Timeout")
                </span>
            </div>
        </div>

    </div>

    <!-- Background Workers Status Panel -->
    <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
        <h3 class="text-xl font-bold text-gray-900 mb-6 border-b border-gray-100 pb-4" style="font-family: 'Poppins', sans-serif;">
            <i class="fa-solid fa-gears text-indigo-600 mr-2"></i> ASP.NET Core Hosted Services Registry
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <!-- Worker 1 -->
            <div class="p-4 bg-gray-50 border border-gray-100 rounded-2xl flex justify-between items-center">
                <div>
                    <h4 class="font-bold text-gray-800 text-sm">ProductSyncService</h4>
                    <p class="text-xs text-gray-500 mt-1">Polls TechCrunch and Hacker News feeds for new launches</p>
                </div>
                <span class="text-xs bg-green-50 text-green-700 px-3 py-1 rounded-full font-bold">
                    <i class="fa-solid fa-circle-play mr-1"></i> Running
                </span>
            </div>

            <!-- Worker 2 -->
            <div class="p-4 bg-gray-50 border border-gray-100 rounded-2xl flex justify-between items-center">
                <div>
                    <h4 class="font-bold text-gray-800 text-sm">ProductEnrichmentService</h4>
                    <p class="text-xs text-gray-500 mt-1">Batches spec fetches, Wikipedia lookups, and AI reports</p>
                </div>
                <span class="text-xs bg-green-50 text-green-700 px-3 py-1 rounded-full font-bold">
                    <i class="fa-solid fa-circle-play mr-1"></i> Running
                </span>
            </div>

            <!-- Worker 3 -->
            <div class="p-4 bg-gray-50 border border-gray-100 rounded-2xl flex justify-between items-center">
                <div>
                    <h4 class="font-bold text-gray-800 text-sm">ImageCollectionService</h4>
                    <p class="text-xs text-gray-500 mt-1">Retrieves and caches missing photos for catalog items</p>
                </div>
                <span class="text-xs bg-green-50 text-green-700 px-3 py-1 rounded-full font-bold">
                    <i class="fa-solid fa-circle-play mr-1"></i> Running
                </span>
            </div>

            <!-- Worker 4 -->
            <div class="p-4 bg-gray-50 border border-gray-100 rounded-2xl flex justify-between items-center">
                <div>
                    <h4 class="font-bold text-gray-800 text-sm">ProductRefreshService</h4>
                    <p class="text-xs text-gray-500 mt-1">Re-evaluates products older than 7 days for updates</p>
                </div>
                <span class="text-xs bg-green-50 text-green-700 px-3 py-1 rounded-full font-bold">
                    <i class="fa-solid fa-circle-play mr-1"></i> Running
                </span>
            </div>

            <!-- Worker 5 -->
            <div class="p-4 bg-gray-50 border border-gray-100 rounded-2xl flex justify-between items-center">
                <div>
                    <h4 class="font-bold text-gray-800 text-sm">DatabaseSyncService</h4>
                    <p class="text-xs text-gray-500 mt-1">Performs continuous replication of data tables between databases</p>
                </div>
                <span class="text-xs bg-amber-50 text-amber-700 px-3 py-1 rounded-full font-bold" title="Awaiting proper Azure network firewall allowance rules">
                    <i class="fa-solid fa-circle-exclamation mr-1"></i> Degraded
                </span>
            </div>

        </div>
    </div>
</div>
