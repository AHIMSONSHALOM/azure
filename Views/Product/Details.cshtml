@model ProductHub_MVC.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a asp-action="Index" class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-blue-600">
                    <i class="fa-solid fa-house mr-2"></i> Dashboard
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <i class="fa-solid fa-chevron-right text-gray-400 text-xs mx-1"></i>
                    <span class="text-sm font-medium text-gray-900 ml-1">Product Details</span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Column: Product Info -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Hero Card -->
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="h-64 w-full overflow-hidden relative">
                        <img src="@Model.ImageUrl" alt="@Model.ProductName" class="w-full h-full object-cover" />
                        <div class="absolute top-4 right-4 bg-white/80 backdrop-blur-md px-4 py-2 rounded-full text-gray-900 font-bold text-sm shadow-sm">
                            <i class="fa-solid fa-star text-yellow-500 mr-1"></i> @Model.ProductRating.ToString("0.0")
                        </div>
                    </div>
                }
                else
                {
                    <div class="h-48 bg-gradient-to-r from-blue-600 to-indigo-600 flex items-center justify-center relative">
                        <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-md px-4 py-2 rounded-full text-white font-bold text-sm">
                            <i class="fa-solid fa-star text-yellow-300 mr-1"></i> @Model.ProductRating.ToString("0.0")
                        </div>
                        <i class="fa-solid fa-rocket text-white/50 text-6xl"></i>
                    </div>
                }
                <div class="p-8">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <span class="text-xs font-bold uppercase tracking-wider text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full mb-3 inline-block">
                                @(string.IsNullOrEmpty(Model.Category) ? "Uncategorized" : Model.Category)
                            </span>
                            <h1 class="text-3xl font-extrabold text-gray-900">@Model.ProductName</h1>
                            <p class="text-gray-500 mt-1 font-medium">by <span class="text-blue-600">@Model.Brand</span></p>
                        </div>
                        <div class="text-right">
                            <p class="text-3xl font-extrabold text-green-600">Rs.@Model.Price.ToString("N0")</p>
                            <p class="text-sm text-gray-400 mt-1">@Model.Quantity in stock</p>
                        </div>
                    </div>
                    
                    <p class="text-gray-600 leading-relaxed text-lg mb-6">
                        @(string.IsNullOrEmpty(Model.ProductDescription) ? "No description provided." : Model.ProductDescription)
                    </p>

                    <div class="flex flex-wrap gap-4">
                        @if (!string.IsNullOrEmpty(Model.ArticleUrl))
                        {
                            <a href="@Model.ArticleUrl" target="_blank" class="inline-flex items-center px-5 py-2.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition shadow-md shadow-blue-500/20 no-underline">
                                <i class="fa-solid fa-newspaper mr-2"></i> Read Source Article
                            </a>
                        }
                        else if (!string.IsNullOrEmpty(Model.Website))
                        {
                            var websiteUrl = Model.Website.StartsWith("http") ? Model.Website : $"https://{Model.Website}";
                            <a href="@websiteUrl" target="_blank" class="inline-flex items-center px-5 py-2.5 bg-gray-900 text-white font-medium rounded-xl hover:bg-gray-800 transition no-underline">
                                <i class="fa-solid fa-globe mr-2"></i> Visit Website
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.WikipediaUrl))
                        {
                            <a href="@Model.WikipediaUrl" target="_blank" class="inline-flex items-center px-5 py-2.5 bg-white border border-gray-200 text-gray-700 font-medium rounded-xl hover:bg-gray-50 transition no-underline">
                                <i class="fa-brands fa-wikipedia-w mr-2 text-purple-600"></i> Read on Wikipedia
                            </a>
                        }
                    </div>
                </div>
            </div>

            <!-- AI Summary Card -->
            <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-3xl p-8 border border-indigo-100 shadow-inner relative overflow-hidden">
                <div class="absolute -right-8 -top-8 text-indigo-100 opacity-50">
                    <i class="fa-solid fa-microchip text-9xl"></i>
                </div>
                <h3 class="text-xl font-bold text-indigo-900 mb-4 flex items-center relative z-10">
                    <i class="fa-solid fa-sparkles text-purple-500 mr-2"></i> AI Generated Summary
                </h3>
                <p class="text-indigo-800/80 leading-relaxed relative z-10">
                    @(string.IsNullOrEmpty(Model.AiSummary) ? "Our AI is currently analyzing this product. The summary will appear here shortly once processed by our local LLM." : Model.AiSummary)
                </p>
            </div>
        </div>

        <!-- Right Column: AI Chatbot / Sidebar -->
        <div class="space-y-8">
            
            <!-- Quick Stats -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
                <h3 class="text-lg font-bold text-gray-900 mb-4">At a glance</h3>
                <ul class="space-y-4">
                    <li class="flex items-center justify-between">
                        <span class="text-gray-500"><i class="fa-regular fa-calendar mr-2"></i> Launched</span>
                        <span class="font-semibold text-gray-900">@(Model.LaunchDate?.ToString("MMM dd, yyyy") ?? "Unknown")</span>
                    </li>
                    <li class="flex items-center justify-between">
                        <span class="text-gray-500"><i class="fa-solid fa-box mr-2"></i> Inventory</span>
                        <span class="font-semibold text-gray-900">@Model.Quantity units</span>
                    </li>
                    <li class="flex items-center justify-between">
                        <span class="text-gray-500"><i class="fa-solid fa-chart-line mr-2"></i> Engagement</span>
                        <span class="font-semibold text-gray-900 text-green-600">High</span>
                    </li>
                </ul>
            </div>

            <!-- AI Chatbot UI -->
            <div class="bg-gray-900 rounded-3xl p-6 shadow-xl flex flex-col h-[400px]">
                <div class="flex items-center mb-4 pb-4 border-b border-gray-800">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 flex items-center justify-center text-white font-bold mr-3">
                        AI
                    </div>
                    <div>
                        <h3 class="text-white font-bold leading-tight">Product Assistant</h3>
                        <p class="text-gray-400 text-xs">Powered by local Ollama</p>
                    </div>
                </div>
                
                <div id="chat-window" class="flex-grow overflow-y-auto mb-4 custom-scrollbar">
                    <div class="bg-gray-800 rounded-2xl rounded-tl-none p-3 max-w-[85%] mb-4">
                        <p class="text-sm text-gray-200">Hi! I can answer any questions about <strong>@Model.ProductName</strong>. What would you like to know?</p>
                    </div>
                </div>

                <div class="relative mt-auto flex">
                    <input type="text" id="chat-input" placeholder="Type your question..." class="w-full bg-gray-800 border-none rounded-xl py-3 pl-4 pr-12 text-sm text-gray-300 focus:ring-2 focus:ring-purple-500 placeholder-gray-500 outline-none" onkeypress="handleKeyPress(event)">
                    <button id="chat-send" onclick="sendMessage()" class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-purple-600 hover:bg-purple-700 transition rounded-lg flex items-center justify-center text-white cursor-pointer shadow-lg shadow-purple-500/30">
                        <i class="fa-solid fa-paper-plane text-xs"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    async function sendMessage() {
        const input = document.getElementById('chat-input');
        const message = input.value.trim();
        if (!message) return;

        // Clear input
        input.value = '';
        input.disabled = true;

        const chatWindow = document.getElementById('chat-window');
        
        // Add User Message
        const userDiv = document.createElement('div');
        userDiv.className = "bg-blue-600 text-white rounded-2xl rounded-tr-none p-3 max-w-[85%] mb-4 ml-auto";
        userDiv.innerHTML = `<p class="text-sm">${message}</p>`;
        chatWindow.appendChild(userDiv);
        chatWindow.scrollTop = chatWindow.scrollHeight;

        // Add Loading indicator
        const loadingDiv = document.createElement('div');
        loadingDiv.className = "bg-gray-800 rounded-2xl rounded-tl-none p-3 max-w-[85%] mb-4 opacity-50";
        loadingDiv.innerHTML = `<p class="text-sm text-gray-400"><i class="fa-solid fa-circle-notch fa-spin"></i> Thinking...</p>`;
        chatWindow.appendChild(loadingDiv);
        chatWindow.scrollTop = chatWindow.scrollHeight;

        try {
            // Call Python FastAPI
            const response = await fetch('http://localhost:8000/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    product_name: "@Html.Raw(Model.ProductName)",
                    product_description: "@Html.Raw(Model.ProductDescription?.Replace("\"", "\\\""))",
                    user_message: message
                })
            });

            if (!response.ok) throw new Error('API Error');
            
            const data = await response.json();
            
            // Remove Loading
            chatWindow.removeChild(loadingDiv);
            
            // Add AI Message
            const aiDiv = document.createElement('div');
            aiDiv.className = "bg-gray-800 border border-purple-500/30 rounded-2xl rounded-tl-none p-3 max-w-[85%] mb-4";
            aiDiv.innerHTML = `<p class="text-sm text-gray-200">${data.reply}</p>`;
            chatWindow.appendChild(aiDiv);

        } catch (error) {
            chatWindow.removeChild(loadingDiv);
            const errorDiv = document.createElement('div');
            errorDiv.className = "bg-red-900/50 border border-red-500/50 rounded-2xl rounded-tl-none p-3 max-w-[85%] mb-4";
            errorDiv.innerHTML = `<p class="text-sm text-red-200">The local AI service requires 'Ollama' to be installed on your machine to generate replies.</p>`;
            chatWindow.appendChild(errorDiv);
        }

        input.disabled = false;
        input.focus();
        chatWindow.scrollTop = chatWindow.scrollHeight;
    }

    function handleKeyPress(e) {
        if (e.key === 'Enter') {
            sendMessage();
        }
    }
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: #1f2937;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #4b5563;
        border-radius: 4px;
    }
</style>
