@model ProductHub_MVC.Models.AiSearchResponse
@{
    ViewData["Title"] = "AI Search Engine Insights";
}

<div class="max-w-6xl mx-auto px-4 py-8">
    
    <!-- User Search Query Header -->
    <div class="mb-8 border-b border-gray-200 pb-6">
        <span class="text-xs font-bold uppercase tracking-wider text-indigo-600 bg-indigo-50 px-3 py-1.5 rounded-full mb-3 inline-block">
            <i class="fa-solid fa-wand-magic-sparkles mr-1 text-purple-500"></i> AI Search Response
        </span>
        <h1 class="text-3xl font-extrabold text-gray-900">“@ViewBag.Query”</h1>
        <p class="text-gray-500 mt-2">Combined insights from Local Database, Web Scraping, and LLM Synthesis.</p>
    </div>

    <!-- Main Content Layout -->
    <div class="row g-4">
        
        <!-- Main Column: AI Answer & Product Cards -->
        <div class="col-lg-8 space-y-6">
            
            <!-- AI Answer Summary Box -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 position-relative overflow-hidden">
                <div class="d-flex align-items-center mb-4">
                    <div class="w-8 h-8 rounded-circle bg-indigo-100 text-indigo-600 d-flex align-items-center justify-content-center mr-2">
                        <i class="fa-solid fa-sparkles text-sm"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 m-0">AI Summary</h3>
                </div>
                
                <!-- Answer Content -->
                <div class="text-gray-700 leading-relaxed text-md pr-lg-4" id="ai-answer-container">
                    @Html.Raw(Model.Answer
                        .Replace("### ", "<h4>")
                        .Replace("#### ", "<h5>")
                        .Replace("**", "<strong>")
                        .Replace("\n\n", "<br/><br/>")
                        .Replace("\n", "<br/>")
                        .Replace("[Local]", "<span class='badge bg-primary bg-opacity-10 text-primary-emphasis px-2 py-1 mx-0.5 rounded'>Local</span>")
                        .Replace("[1]", "<a href='#source-1' class='badge bg-indigo bg-opacity-10 text-indigo-emphasis px-2 py-0.5 mx-0.5 rounded text-decoration-none'>[1]</a>")
                        .Replace("[2]", "<a href='#source-2' class='badge bg-indigo bg-opacity-10 text-indigo-emphasis px-2 py-0.5 mx-0.5 rounded text-decoration-none'>[2]</a>")
                        .Replace("[3]", "<a href='#source-3' class='badge bg-indigo bg-opacity-10 text-indigo-emphasis px-2 py-0.5 mx-0.5 rounded text-decoration-none'>[3]</a>")
                        .Replace("[4]", "<a href='#source-4' class='badge bg-indigo bg-opacity-10 text-indigo-emphasis px-2 py-0.5 mx-0.5 rounded text-decoration-none'>[4]</a>")
                        .Replace("[5]", "<a href='#source-5' class='badge bg-indigo bg-opacity-10 text-indigo-emphasis px-2 py-0.5 mx-0.5 rounded text-decoration-none'>[5]</a>")
                    )
                </div>
            </div>

            <!-- Scraped Web Images Section -->
            @if (Model.Images != null && Model.Images.Count > 0)
            {
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100">
                    <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fa-regular fa-image text-indigo-600 mr-2"></i> Scraped Product Images
                    </h3>
                    <div class="row g-2">
                        @foreach (var img in Model.Images)
                        {
                            <div class="col-4 col-md-3">
                                <div class="ratio ratio-1x1 border rounded-2xl overflow-hidden shadow-sm bg-gray-50 hover:scale-105 transition-all cursor-zoom-in" onclick="viewFullImage('@img')">
                                    <img src="@img" class="w-100 h-100 object-fit-cover" style="object-fit: cover;" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Product Cards section (Database + Discovered Web Results) -->
            <div class="space-y-4">
                <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                    <i class="fa-solid fa-box text-indigo-600 mr-2"></i> Relevant Products
                </h3>

                <div class="row g-3">
                    @foreach (var card in Model.ProductCards)
                    {
                        <div class="col-md-6">
                            <div class="bg-white rounded-3xl p-4 shadow-sm border border-gray-100 h-100 d-flex flex-col justify-content-between">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge bg-@(card.Brand == "Web Result" ? "secondary" : "primary") px-2.5 py-1">
                                            @(card.Brand == "Web Result" ? "🌐 Discovered Web" : "📦 In-Store Inventory")
                                        </span>
                                        <span class="text-xs text-muted fw-bold text-uppercase">@card.Category</span>
                                    </div>
                                    <h4 class="text-lg font-bold text-gray-900 mb-2">@card.Name</h4>
                                    <p class="text-xs text-gray-500 line-clamp-3">@card.Description</p>
                                </div>
                                
                                <div class="mt-4 pt-3 border-top border-gray-100">
                                    @if (card.Brand == "Web Result")
                                    {
                                        <a href="@card.Url" target="_blank" class="btn btn-sm btn-outline-secondary w-100 rounded-pill font-semibold py-2">
                                            <i class="fa-solid fa-arrow-up-right-from-square mr-1"></i> Visit Web Source
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/Product/Details/@card.Id" class="btn btn-sm btn-outline-primary w-100 rounded-pill font-semibold py-2" style="border-color: #6366f1; color: #6366f1;">
                                            <i class="fa-solid fa-eye mr-1"></i> View Intelligence Page
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- Right Column: Sources & Related Queries -->
        <div class="col-lg-4 space-y-6">
            
            <!-- Citation Sources List -->
            <div class="bg-white rounded-3xl p-5 shadow-sm border border-gray-100">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                    <i class="fa-solid fa-link text-indigo-600 mr-2"></i> Citation Sources
                </h3>
                <div class="list-group list-group-flush border-0">
                    @foreach (var src in Model.Sources)
                    {
                        <a id="source-@src.Id" href="@src.Url" target="_blank" class="list-group-item list-group-item-action bg-transparent border-0 px-0 py-2.5 d-flex align-items-start gap-2 text-decoration-none">
                            <span class="badge bg-indigo text-indigo-emphasis bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; flex-shrink: 0;">
                                @src.Id
                            </span>
                            <div class="overflow-hidden">
                                <p class="text-sm font-bold text-gray-900 m-0 text-truncate">@src.Name</p>
                                <span class="text-xs text-muted text-truncate d-block">@src.Url</span>
                            </div>
                        </a>
                    }
                </div>
            </div>

            <!-- Related Queries List -->
            <div class="bg-white rounded-3xl p-5 shadow-sm border border-gray-100">
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                    <i class="fa-solid fa-circle-question text-indigo-600 mr-2"></i> Related Questions
                </h3>
                <ul class="list-group list-group-flush border-0">
                    @foreach (var query in Model.RelatedProducts)
                    {
                        <li class="list-group-item bg-transparent border-0 px-0 py-2">
                            <a href="/Product/Search?q=@System.Net.WebUtility.UrlEncode(query)" class="text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition text-decoration-none d-flex align-items-start gap-2">
                                <i class="fa-solid fa-magnifying-glass text-xs mt-1 text-muted"></i>
                                <span>@query</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>

        </div>
    </div>
</div>

<!-- Modal for full image view -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 bg-transparent text-center">
            <div class="modal-body p-0 position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 shadow" data-bs-dismiss="modal"></button>
                <img id="fullViewImage" src="" class="img-fluid rounded-3 shadow-lg" style="max-height: 80vh;" />
            </div>
        </div>
    </div>
</div>

<script>
    function viewFullImage(url) {
        document.getElementById('fullViewImage').src = url;
        new bootstrap.Modal(document.getElementById('imageModal')).show();
    }
</script>
