<div class="modal fade" id="importExcelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow" style="border-radius: 12px; overflow: hidden;">
            <form asp-action="ImportData" method="post" enctype="multipart/form-data">
                <div class="modal-header text-white border-0 py-3" style="background-color: var(--primary-color);"><h5 class="modal-title fw-bold m-0"><i class="fa-solid fa-file-import me-2"></i>Import Excel</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                <div class="modal-body p-4 small">
                    <div class="mb-3"><label class="form-label fw-bold">Select File</label><input type="file" name="alexaExcelFile" class="form-control" accept=".xlsx" required /></div>
                </div>
                <div class="modal-footer bg-light border-0"><button type="button" class="btn btn-saas-secondary py-2 px-3" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-saas-primary py-2 px-4">Import</button></div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="dispatchCheckedEmailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow" style="border-radius: 12px; overflow: hidden;">
            <div class="modal-header text-white border-0 py-3" style="background-color: var(--primary-color);"><h5 class="modal-title fw-bold m-0"><i class="fa-solid fa-envelope me-2"></i>Email Data</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-4 small">
                <div class="mb-3"><label class="form-label fw-bold">Email Address</label><input type="email" id="modalEmailInputBox" class="form-control" placeholder="recipient@gmail.com" required /></div>
            </div>
            <div class="modal-footer bg-light border-0"><button type="button" class="btn btn-saas-secondary py-2 px-3" data-bs-dismiss="modal">Cancel</button><button type="button" onclick="executeCheckedEmailPipeline()" class="btn btn-saas-primary py-2 px-4">Send Email</button></div>
        </div>
    </div>
</div>

<script>
    function applySort(sortValue) {
        document.querySelector('#filterForm input[name="sortBy"]').value = sortValue;
        document.getElementById('filterForm').submit();
    }
    
    function showSyncLoading() {
        const btn = document.getElementById('btnSyncFeeds');
        const icon = document.getElementById('syncIcon');
        const text = document.getElementById('syncText');
        if (icon) {
            icon.className = 'fa-solid fa-spinner fa-spin me-1';
        }
        if (text) text.innerText = 'Syncing Live Products...';
        setTimeout(() => { if (btn) btn.disabled = true; }, 50);
    }
    
    document.getElementById('selectAllBoxes').addEventListener('change', function() {
        let boxes = document.querySelectorAll('.row-item-checkbox');
        boxes.forEach(box => box.checked = this.checked);
    });
    function triggerComparison() {
        let checkboxes = document.querySelectorAll('.row-item-checkbox:checked');
        if (checkboxes.length < 2 || checkboxes.length > 4) { alert("Please check between 2 and 4 rows to Compare."); return; }
        let urlParams = Array.from(checkboxes).map(box => "ids=" + box.value).join("&");
        window.location.href = "/Product/Compare?" + urlParams;
    }
    function triggerExport() {
        let form = document.getElementById('filterForm');
        let brand = form.querySelector('[name="brandFilter"]')?.value || "";
        let minP = form.querySelector('[name="minPrice"]').value;
        let maxP = form.querySelector('[name="maxPrice"]').value;
        let rating = form.querySelector('[name="minRating"]:checked')?.value || "";
        window.location.href = `/Product/ExportData?brandFilter=${encodeURIComponent(brand)}&minPrice=${minP}&maxPrice=${maxP}&minRating=${rating}`;
    }
    function executeCheckedEmailPipeline() {
        let boxes = document.querySelectorAll('.row-item-checkbox:checked');
        let mailAddress = document.getElementById('modalEmailInputBox').value.trim();
        if (!mailAddress || boxes.length === 0) { alert("Selection and Email entry required."); return; }
        let form = document.getElementById('checkedItemsForm');
        form.action = `/Product/EmailZipData?recipientEmail=${encodeURIComponent(mailAddress)}`;
        form.submit();
    }
    function triggerDeletePost(id) {
        if(confirm("Delete this record component permanently?")) {
            let f = document.createElement('form'); f.method = 'POST'; f.action = '/Product/DeleteProduct/' + id;
            document.body.appendChild(f); f.submit();
        }
    }
    function triggerEditModal(id, name, brand, qty, price, rating, desc, category, subcategory) {
        document.getElementById('edit_ProductId').value = id; document.getElementById('edit_ProductName').value = name;
        if(document.getElementById('edit_Brand')) { document.getElementById('edit_Brand').value = brand; }
        document.getElementById('edit_Quantity').value = qty;
        document.getElementById('edit_Price').value = price; document.getElementById('edit_Rating').value = rating;
        document.getElementById('edit_Description').value = desc;
        
        const catSelect = document.getElementById('edit_Category');
        if (catSelect) {
            catSelect.value = category || "";
            updateSubcategories('edit', subcategory || "");
        }
        
        new bootstrap.Modal(document.getElementById('editProductModal')).show();
    }

    const subcategoriesMap = {
        "Mobiles": ["Smartphones", "Tablets", "Accessories"],
        "Electronics": ["Laptops", "TVs", "Monitors", "Cameras", "Speakers"],
        "Home Appliances": ["Refrigerator", "Washing Machine", "AC", "Water Purifier", "Microwave"],
        "Grocery": ["Rice", "Oil", "Vegetables", "Packaged Foods", "Beverages"],
        "Plumbing Materials": ["Pipes", "Valves", "Water Tanks", "Fittings"],
        "Electrical Materials": ["Wires", "Switches", "MCB", "Lights", "Fans"],
        "Hardware & Tools": ["Tools", "Fasteners", "Paints"],
        "Automotive": ["Bike Parts", "Car Parts", "Lubricants"],
        "Furniture": ["Sofa", "Bed", "Table", "Chair", "Wardrobe"],
        "Fashion": ["Clothing", "Footwear", "Accessories"],
        "Healthcare": ["Medical Equipment", "Healthcare Products"],
        "Building Materials": ["Cement", "Bricks", "Steel", "Tiles"],
        "Kitchen Products": ["Cookware", "Cutlery", "Chimney", "Blender"]
    };

    function updateSubcategories(prefix, selectedSub = "") {
        const catSelect = document.getElementById(prefix + '_Category');
        const subSelect = document.getElementById(prefix + '_Subcategory');
        if (!catSelect || !subSelect) return;
        
        const category = catSelect.value;
        subSelect.innerHTML = '<option value="">-- Select Subcategory --</option>';
        
        if (category && subcategoriesMap[category]) {
            subcategoriesMap[category].forEach(sub => {
                const opt = document.createElement('option');
                opt.value = sub;
                opt.textContent = sub;
                if (sub === selectedSub) {
                    opt.selected = true;
                }
                subSelect.appendChild(opt);
            });
        }
    }
</script>