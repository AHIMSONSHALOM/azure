@model IEnumerable<ProductHub_MVC.Models.Product>
@{
    ViewData["Title"] = "PRODUCTHUB CONSOLE";
    int sequentialNumber = 1;
}

@functions {
    public string GetStarRating(double rating) {
        int rounded = (int)Math.Round(rating);
        string stars = "";
        for (int i = 1; i <= 5; i++) {
            if (i <= rounded) stars += "★";
            else stars += "☆";
        }
        return stars;
    }

    public string GetCleanDescription(string rawDesc) {
        if (string.IsNullOrEmpty(rawDesc)) return "No description available for this product yet. Click to view more details and AI insights.";
        if (!rawDesc.Trim().StartsWith("{")) return rawDesc;
        try {
            using var doc = System.Text.Json.JsonDocument.Parse(rawDesc);
            if (doc.RootElement.TryGetProperty("description", out var prop)) {
                return prop.GetString() ?? rawDesc;
            }
        } catch { }
        return rawDesc;
    }
}

<div class="container-fluid mt-1 saas-grid-gap">
    <!-- Top Dashboard Header with Premium Buttons -->
    <div class="saas-card mb-0 border-0 shadow-sm p-3 p-lg-4">
        <div class="row g-2 align-items-stretch w-100 m-0">
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                <a href="/Product/Dashboard" class="btn btn-saas-secondary w-100 h-100 justify-content-center text-nowrap" style="background: linear-gradient(135deg, #10b981, #059669); border: none; color: white;">
                    <i class="fa-solid fa-chart-simple me-1"></i> Market Dashboard
                </a>
            </div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                <form asp-action="SyncLiveFeeds" method="post" class="w-100 h-100 m-0" onsubmit="showSyncLoading()">
                    <button type="submit" id="btnSyncFeeds" class="btn btn-saas-primary w-100 h-100 justify-content-center text-nowrap" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); border: none;">
                        <i class="fa-solid fa-rotate me-1" id="syncIcon"></i> <span id="syncText">Sync Live Products</span>
                    </button>
                </form>
            </div>
            @if (ViewBag.CanAddRow == 1)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                    <button class="btn btn-saas-primary w-100 h-100 justify-content-center text-nowrap" data-bs-toggle="modal" data-bs-target="#addProductModal">
                        <i class="fa-solid fa-plus me-1"></i> Add Product
                    </button>
                </div>
            }
            @if (ViewBag.CanDownload == 1)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                    <a asp-action="DownloadTemplate" class="btn btn-saas-secondary w-100 h-100 justify-content-center text-nowrap">
                        <i class="fa-solid fa-download me-1"></i> Download Template
                    </a>
                </div>
            }
            @if (ViewBag.CanImport == 1)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                    <button class="btn btn-saas-secondary w-100 h-100 justify-content-center text-nowrap" data-bs-toggle="modal" data-bs-target="#importExcelModal">
                        <i class="fa-solid fa-file-import me-1"></i> Import Excel
                    </button>
                </div>
            }
            @if (ViewBag.CanExport == 1)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                    <a href="#" onclick="triggerExport()" class="btn btn-saas-secondary w-100 h-100 justify-content-center text-nowrap">
                        <i class="fa-solid fa-file-export me-1"></i> Export Excel
                    </a>
                </div>
            }
            @if (ViewBag.CanCompare == 1)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                    <button type="button" onclick="triggerComparison()" class="btn btn-saas-primary w-100 h-100 justify-content-center text-nowrap">
                        <i class="fa-solid fa-code-compare me-1"></i> Compare Products
                    </button>
                </div>
            }
            @if (ViewBag.CanEmail == 1)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl">
                    <button type="button" data-bs-toggle="modal" data-bs-target="#dispatchCheckedEmailModal" class="btn btn-saas-primary w-100 h-100 justify-content-center text-nowrap">
                        <i class="fa-solid fa-envelope me-1"></i> Email Data
                    </button>
                </div>
            }
        </div>
    </div>

    @if (ViewBag.ForcedIsolationNotice != null)
    {
        <div class="alert alert-warning border-0 bg-white shadow-sm p-3 mx-1 mb-0 small fw-bold text-dark rounded border-start border-4 border-warning d-flex align-items-center">
            <i class="fa-solid fa-shield-halved text-warning fs-5 me-2"></i>
            <span>@ViewBag.ForcedIsolationNotice</span>
        </div>
    }

    <div class="row g-4">
        <!-- Sidebar filters -->
        <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
            <div class="saas-sidebar">
                <h4 class="saas-sidebar-title">
                    <i class="fa-solid fa-filter text-primary me-2"></i>Filters
                </h4>
                <form id="filterForm" method="get" asp-action="Index">
                    <input type="hidden" name="sortBy" value="@ViewBag.CurrentSort" />
                    
                    @if (ViewBag.CanSeeBrand == 1)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">Brands</label>
                            <input type="text" name="brandFilter" value="@ViewBag.CurrentBrand" class="form-control" placeholder="Search product line..." />
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small">Price Range</label>
                        <div class="d-flex gap-2">
                            <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control" placeholder="Min" />
                            <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="Max" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-saas-primary w-100 fw-bold py-2 mb-2">Apply Filters</button>
                    <a asp-action="Index" class="btn btn-saas-secondary w-100 fw-semibold py-2">Reset Filters</a>
                </form>
                
                <div class="mt-4 pt-4 border-top border-secondary border-opacity-10">
                    <h5 class="saas-sidebar-title mb-3 fs-6">
                        <i class="fa-solid fa-tags text-primary me-2"></i>Categories
                    </h5>
                    <div class="list-group list-group-flush border-0">
                        <a href="/Product/Category?cat=Mobiles" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-mobile-screen me-2 text-primary"></i> Mobiles</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Electronics" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-laptop me-2 text-primary"></i> Electronics</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Home+Appliances" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-house-chimney me-2 text-primary"></i> Home Appliances</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Grocery" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-basket-shopping me-2 text-primary"></i> Grocery</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Plumbing+Materials" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-faucet-drip me-2 text-primary"></i> Plumbing Materials</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Electrical+Materials" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-plug me-2 text-primary"></i> Electrical Materials</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Hardware+%26+Tools" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-hammer me-2 text-primary"></i> Hardware & Tools</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                        <a href="/Product/Category?cat=Furniture" class="list-group-item list-group-item-action bg-transparent border-0 py-2 px-1 d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-semibold"><i class="fa-solid fa-chair me-2 text-primary"></i> Furniture</span>
                            <i class="fa-solid fa-chevron-right text-muted small"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Inventory List Table -->
        <div class="col-lg-9 col-md-8">
            <div class="saas-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <form id="checkedItemsForm" method="post">
                        <!-- Feed Header -->
                        <div class="flex justify-between items-center mb-6 px-2">
                            <h2 class="text-2xl font-extrabold text-gray-800 tracking-tight">Product Feed <span class="text-blue-500 text-sm align-top ml-2">@Model.Count() items</span></h2>
                            <div class="flex items-center space-x-4">
                                <a href="javascript:void(0);" onclick="applySort('Latest')" class="text-sm font-semibold text-gray-600 hover:text-blue-600 transition">Latest Launches</a>
                                <a href="javascript:void(0);" onclick="applySort('Trending')" class="text-sm font-semibold text-gray-600 hover:text-blue-600 transition">🔥 Trending</a>
                            </div>
                        </div>

                        <!-- Tailwind Grid of Products -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            @foreach (var prod in Model)
                            {
                                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden relative group flex flex-col h-full">
                                    <div class="absolute top-4 left-4 z-10 flex items-center space-x-2">
                                        <input type="checkbox" name="ids" value="@prod.ProductId" class="w-5 h-5 text-blue-600 rounded focus:ring-blue-500 form-check-input row-item-checkbox shadow-sm cursor-pointer" />
                                    </div>
                                    <div class="absolute top-4 right-4 z-10 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-xs font-bold shadow-sm border border-gray-100">
                                        <span class="text-yellow-500">★</span> @prod.ProductRating.ToString("0.0")
                                    </div>

                                    <!-- Product Image -->
                                    @if (!string.IsNullOrEmpty(prod.ImageUrl))
                                    {
                                        <div class="h-40 w-full overflow-hidden relative">
                                            <img src="@prod.ImageUrl" alt="@prod.ProductName" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- Product Image Placeholder (Gradient) -->
                                        <div class="h-40 w-full bg-gradient-to-br from-indigo-50 to-blue-100 flex items-center justify-center p-6 relative">
                                            <i class="fa-solid fa-cube text-indigo-300 text-5xl"></i>
                                        </div>
                                    }

                                    <!-- Product Details -->
                                    <div class="p-6 flex-grow flex flex-col">
                                        <div class="flex justify-between items-start mb-2">
                                            <h3 class="text-lg font-bold text-gray-900 leading-tight">@prod.ProductName</h3>
                                            @if (ViewBag.CanSeePrice == 1) { 
                                                <span class="text-lg font-extrabold text-green-600 bg-green-50 px-2 py-1 rounded-lg">Rs.@prod.Price.ToString("N0")</span>
                                            }
                                        </div>
                                        
                                        @if (ViewBag.CanSeeBrand == 1) {
                                            <p class="text-sm text-gray-500 font-medium mb-3">by <span class="text-blue-600">@prod.Brand</span></p>
                                        }

                                        <p class="text-gray-600 text-sm line-clamp-3 mb-4 flex-grow">
                                            @GetCleanDescription(prod.ProductDescription)
                                        </p>

                                        @if (!string.IsNullOrEmpty(prod.ArticleUrl) || !string.IsNullOrEmpty(prod.WikipediaUrl))
                                        {
                                            <div class="flex flex-wrap gap-2 mb-3">
                                                @if (!string.IsNullOrEmpty(prod.ArticleUrl))
                                                {
                                                    <a href="@prod.ArticleUrl" target="_blank" class="inline-flex items-center gap-1 text-xs bg-gray-100 hover:bg-blue-50 text-gray-700 hover:text-blue-700 font-semibold px-2.5 py-1 rounded-full transition no-underline">
                                                        <i class="fa-solid fa-newspaper text-blue-500"></i> Source
                                                    </a>
                                                }
                                                @if (!string.IsNullOrEmpty(prod.WikipediaUrl))
                                                {
                                                    <a href="@prod.WikipediaUrl" target="_blank" class="inline-flex items-center gap-1 text-xs bg-gray-100 hover:bg-purple-50 text-gray-700 hover:text-purple-700 font-semibold px-2.5 py-1 rounded-full transition no-underline">
                                                        <i class="fa-brands fa-wikipedia-w text-purple-500"></i> Wikipedia
                                                    </a>
                                                }
                                            </div>
                                        }

                                        <!-- Footer Actions -->
                                        <div class="pt-4 border-t border-gray-100 flex justify-between items-center mt-auto">
                                            <a href="/Product/Details/@prod.ProductId" class="inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-800 transition no-underline">
                                                View Details <i class="fa-solid fa-arrow-right ml-1 text-xs"></i>
                                            </a>
                                            
                                            <div class="flex space-x-2">
                                                @if (ViewBag.CanUseEdit == 1)
                                                {
                                                    <button type="button" class="w-8 h-8 rounded-full bg-gray-50 hover:bg-indigo-100 text-indigo-600 flex items-center justify-center transition" onclick="triggerEditModal('@prod.ProductId', '@prod.ProductName', '@prod.Brand', '@prod.Quantity', '@prod.Price', '@prod.ProductRating', '@prod.ProductDescription', '@prod.Category', '@prod.Subcategory')"><i class="fa-solid fa-pen text-xs"></i></button>
                                                }
                                                @if (ViewBag.CanUseDelete == 1)
                                                {
                                                    <button type="button" class="w-8 h-8 rounded-full bg-gray-50 hover:bg-red-100 text-red-600 flex items-center justify-center transition" onclick="triggerDeletePost('@prod.ProductId')"><i class="fa-solid fa-trash text-xs"></i></button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

